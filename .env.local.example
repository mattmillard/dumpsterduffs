# Supabase Configuration
# Get these from: https://app.supabase.com → Your Project → Settings → API

# Public (safe in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://jimuzkuyozueaxxoyllh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Secret (backend only - NEVER expose to frontend or GitHub)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe Configuration (optional - for payment processing)
# Get from: https://dashboard.stripe.com → Developers → API Keys

# Public (safe in frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Secret (backend only)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Booking confirmation email (optional)
# Use Resend API key to send transactional booking confirmations
RESEND_API_KEY=re_test
BOOKING_FROM_EMAIL=bookings@yourdomain.com

# Google Maps API (optional - for address autofill from geolocation)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Geocoding API, Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Database Configuration (optional - direct PostgreSQL access)
# Only needed if connecting directly to Postgres
# DATABASE_URL=postgresql://postgres:your_password@db.jimuzkuyozueaxxoyllh.supabase.co:5432/postgres
